# Configuración externa (contrato con el operador).
# Estos nombres se mantienen tal cual los expone la plataforma de origen;
# el código interno los consume vía adapters/platform_config.py de forma agnóstica.

# Endpoint base para chat completions (incluye trailing slash).
ES_URL_CHAT=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/<instance-id>/v1/orchestrate/

# Endpoint de obtención de token.
ES_URL_TOKEN=https://iam.cloud.ibm.com/identity/token

# Endpoint para descubrir agentes disponibles (usado solo para validar AGENT_ID).
ES_AGENTS_URL=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/<instance-id>/v1/orchestrate/agents

# API key (NO commitear el valor real).
ES_TOKEN=

# ID del agente bajo test. Selección fija por configuración.
AGENT_ID=

# Umbral de accuracy bajo el cual el runner retorna exit code != 0 (opcional, default 0.0).
ACCURACY_THRESHOLD=0.0
